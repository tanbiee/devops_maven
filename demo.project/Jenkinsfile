pipeline{
    agent none
    stages{
        stage('Build'){
            agent { label 'built-in'}
            steps{
                dir('demo.project'){
                    echo 'building application'
                }
                
            }
        }
        stage('test'){
            agent {label 'built-in'}
            steps{
                dir('demo.project'){
                    echo 'testing application throughly'
                }
                
            }
        }
        stage('deploye'){
            agent {label 'built-in'}
            steps{
                dir('demo.project'){
                    echo 'deployinh th application'
                }
                
            }
        }
    }
}