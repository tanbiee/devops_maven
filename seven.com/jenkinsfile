pipeline{
    agent any
    stages{
        stage('building docker'){
            steps{
                dir('seven.com'){
                    bat 'docker run --rm -v "%WORKSPACE%/seven.com:/app" -w /app maven:3.8.4-openjdk-17 mvn clean package -DskipTests'
                }
            }
        }
        stage('build & test'){
            steps{
                dir('seven.com'){
                    echo 'running building stage in devops...'
                    echo 'compiling and validating the stage...'
                    bat 'mvn clean package -DskipTests'
                    echo 'this is the test phase in devops...'
                    echo 'testing the repository....'
                }
            }
        }
        stage('deploy'){
            steps{
                dir('seven.com'){
                    echo 'this is the last step of deployment in devops...'
                    echo 'deployed done'
                }
            }
        }
        
    }
}