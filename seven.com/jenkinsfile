pipeline{
    agent any
    stages{
        stage('building docker'){
            steps{
                dir('seven.com'){
                    bat 'docker run --rm -v "%WORKSPACE%:/app" -w /app maven:3.8.4-openjdk-17 mvn clean package -DskipTests'
                }
            }
        }
        stage('deploy'){
            steps{
                dir('seven.com'){
                    echo 'this is the last step of deployment in devops...'
                    echo 'deployed done'
                }
            }
        }
        
    }
}