pipeline{
    agent{
        docker{
            image 'maven:3.9-eclipse-temurin-17'

        }
    }
    stages{
        stage('build & test'){
            steps{
                dir('seven.com'){
                    echo 'running building stage in devops...'
                    echo 'compiling and validating the stage...'
                    bat 'mvn clean package -DskipTests'
                    echo 'this is the test phase in devops...'
                    echo 'testing the repository....'
                }
            }
        }
        stage('deploy'){
            steps{
                dir('seven.com'){
                    echo 'this is the last step of deployment in devops...'
                    echo 'deployed done'
                }
            }
        }
        
    }
}